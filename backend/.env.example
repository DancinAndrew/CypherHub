APP_ENV=development
FLASK_DEBUG=1
# 雲端 Supabase: https://your-project.supabase.co
# 本地 Supabase (Docker): http://host.docker.internal:54321
# 本地 Supabase (flask run 本機): http://127.0.0.1:54321
SUPABASE_URL=
SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
CORS_ORIGINS=http://localhost:5173
ADMIN_ALLOWLIST=
# 前端網址（報名成功信中的「我的票券」連結）
FRONTEND_BASE_URL=http://localhost:5173
# 選填：Resend API key 設定後報名成功會寄信；未設定則僅 log
# RESEND_API_KEY=
# RESEND_FROM_EMAIL=CypherHub <onboarding@resend.dev>
